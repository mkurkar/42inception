# Sample Environment Variables File
# Copy this to srcs/.env and customize with your values
# IMPORTANT: Never commit the actual .env file with real passwords!

# Domain Configuration
DOMAIN_NAME=mkurkar.42.fr

# MySQL/MariaDB Configuration
# Note: Actual passwords are stored in secrets/ directory
MYSQL_ROOT_PASSWORD_FILE=/run/secrets/db_root_password
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
MYSQL_PASSWORD_FILE=/run/secrets/db_password

# WordPress Configuration
# Passwords are stored in secrets/ directory (wp_admin_password.txt, wp_user_password.txt)
WP_ADMIN_USER=mkurkar_wp
WP_ADMIN_EMAIL=mkurkar@student.42.fr

WP_USER=mkurkar_user
WP_USER_EMAIL=mkurkar_user@student.42.fr

WP_TITLE=Inception WordPress
WP_URL=https://mkurkar.42.fr

# Data paths on host
DATA_PATH=/home/mkurkar/data
